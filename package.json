{
  "name": "aurum-grace-nextjs",
  "version": "1.0.0",
  "description": "Aurum & Grace Jewellery Shop — Next.js Frontend + Express Backend",
  "scripts": {
    "dev": "concurrently \"npm run next-dev\" \"npm run api-dev\"",
    "next-dev": "next dev -p 3001",
    "api-dev": "nodemon api/server.js",
    "build": "next build",
    "start": "next start -p 3001",
    "seed": "node api/scripts/seed.js"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "connect-mongo": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "mongoose": "^8.3.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}